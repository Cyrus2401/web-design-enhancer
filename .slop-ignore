# .slop-ignore — Anti-false-positive whitelist for detect_ai_slop.py
#
# Declare here legitimate project patterns to avoid false positives.
# Syntax: one rule per line.
# Comments: lines starting with #
# Sections: [icons], [buzzwords], [gradients], [badges], [fonts]
#
# Example:
#   [icons]
#   search          # functional search icon in the navigation bar
#   check           # validation icon in forms
#
#   [buzzwords]
#   premium         # used as a real pricing plan name (Premium plan)
#
# -----------------------------------------------------------------------------
# RULE: every entry must be justified by a comment.
# No comment = the rule is ignored.
# -----------------------------------------------------------------------------

[icons]
# Add here Lucide/Heroicons icons used functionally
# search       # search bar in the main nav
# check        # form validation state
# mail         # contact mailto link

[buzzwords]
# Add here buzzwords that have a precise meaning in this project
# premium      # pricing plan name (not a vague adjective)

[gradients]
# Add here intentional gradients with justification
# gradient     # static mesh gradient inspired by Stripe (refs/antipatterns-guide.md §4)

[badges]
# Add here legitimate status badge patterns
# LIVE         # live indicator on the analytics dashboard (real data)

[files]
# Add here files or folders to ignore completely
# scripts/     # internal skill scripts (search.py, core.py...)
# node_modules/
# dist/
