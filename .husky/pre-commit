#!/usr/bin/env sh
# web-design-enhancer-pro — pre-commit hook
# Blocks the commit if DESIGN.md is invalid.
#
# Install: npx husky install && chmod +x .husky/pre-commit
# Bypass (last resort only): git commit --no-verify

. "$(dirname -- "$0")/_/husky.sh" 2>/dev/null || true

PY="${PYTHON:-python3}"

if [ ! -f "DESIGN.md" ]; then
  echo "[INFO] No DESIGN.md at repo root - skipping web-design-enhancer pre-commit."
  exit 0
fi

echo "[CHECK] web-design-enhancer - validating DESIGN.md (gate 1)..."

# Gate 0 (verify Phase 0 was executed)
"$PY" scripts/check.py --gate 0 || {
  echo ""
  echo "[BLOCKED] Commit blocked: Phase 0 not proven."
  echo "   -> Run Phase 0 (getdesign.md + UI/UX Pro Max) then retry."
  exit 1
}

# Gate 1 (validate the DESIGN.md contract)
"$PY" scripts/check.py --gate 1 || {
  echo ""
  echo "[BLOCKED] Commit blocked: DESIGN.md invalid."
  echo "   -> Fix the errors above then retry git commit."
  exit 1
}

echo "[OK] DESIGN.md valid - commit authorized."
